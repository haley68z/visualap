-- ===================== RÉCUPÉRATION DU NOM @CIBLE =====================
local function getGiftingTarget()
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Text:find("GIFTING:") then
            return v.Text:gsub("GIFTING:", ""):gsub("@", ""):gsub(" ", "")
        end
    end
    return "Joueur"
end

