-- Fonction de vérification (insensible à la casse et aux espaces)
local function checkWhitelist(player)
    local playerName = player.Name:lower():gsub("%s+", "")
    for _, name in ipairs(Whitelist) do
        if name:lower():gsub("%s+", "") == playerName then
            return true
        end
    end
    return false
end

