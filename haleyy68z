    -- AFFICHAGE DE TES ROBUX EN HAUT (TON SOLDE CHOISI)
    local rbuxBalance = Instance.new("TextLabel")
    rbuxBalance.Size = UDim2.new(0.4, 0, 0, 40)
    rbuxBalance.Position = UDim2.new(0.55, 0, 0, 10)
    rbuxBalance.Text = " " .. fakeRobuxTotal -- ICI TON SOLDE
    rbuxBalance.TextColor3 = Color3.fromRGB(255, 255, 255)
    rbuxBalance.TextSize = 16
    rbuxBalance.Font = Enum.Font.GothamMedium
    rbuxBalance.TextXAlignment = Enum.TextXAlignment.Right
    rbuxBalance.BackgroundTransparency = 1
    rbuxBalance.Parent = frame

    local buyBtn = Instance.new("TextButton")
    buyBtn.Size = UDim2.new(0.9, 0, 0, 45)
    buyBtn.Position = UDim2.new(0.05, 0, 0.7, 0)
    buyBtn.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
    buyBtn.Text = "Buy"
    buyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    buyBtn.Font = Enum.Font.GothamBold
    buyBtn.Parent = frame
    Instance.new("UICorner", buyBtn)

    -- Barre de chargement
    local loadBg = Instance.new("Frame")
    loadBg.Size = buyBtn.Size
    loadBg.Position = buyBtn.Position
    loadBg.BackgroundColor3 = Color3.fromRGB(0, 80, 130)
    loadBg.Visible = false
    loadBg.Parent = frame
    Instance.new("UICorner", loadBg)
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0,0,1,0)
    bar.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    bar.Parent = loadBg
    Instance.new("UICorner", bar)

    buyBtn.MouseButton1Click:Connect(function()
        buyBtn.Visible = false
        loadBg.Visible = true
        local t = TweenService:Create(bar, TweenInfo.new(1.5), {Size = UDim2.new(1,0,1,0)})
        t:Play()
        t.Completed:Connect(function()
            frame:Destroy()
            if fakeRobuxTotal >= price then
                fakeRobuxTotal = fakeRobuxTotal - price
                showPurchaseCompleted(itemName)
            end
        end)
    end)
end

-- ===================== DÉTECTION DU BOUTON VERT 7,499 =====================
UserInputService.InputBegan:Connect(function(input, proc)
    if not proc then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        task.wait(0.05)
        local mPos = UserInputService:GetMouseLocation()
        local objects = pGui:GetGuiObjectsAtPosition(mPos.X, mPos.Y)
        for _, obj in ipairs(objects) do
            -- On vérifie si on clique sur le bouton qui contient le prix "7,499"
            if (obj:IsA("TextButton") or obj:IsA("TextLabel")) and obj.Text:find("7,499") then
                showBuyItemMenu("Admin Commands", 7499)
                break
            end
        end
    end
end)

