-- Animation et Logique
local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Linear)
local progressTween = TweenService:Create(ProgressBar, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})

local function openMenu()
	if not ScreenGui.Enabled then
		ScreenGui.Enabled = true
		ProgressBar.Size = UDim2.new(0, 0, 1, 0) -- Reset la barre
		canClick = false -- On bloque le bouton au départ
		BuyContainer.AutoButtonColor = false -- Pas d'effet visuel de clic
		
		progressTween:Play()
		
		-- On attend la fin de l'animation pour libérer le bouton
		progressTween.Completed:Connect(function()
			canClick = true
			BuyContainer.AutoButtonColor = true -- Le bouton redevient réactif visuellement
		end)
	else
		ScreenGui.Enabled = false
	end
end

-- Gestion du clic sur le bouton Buy
BuyContainer.MouseButton1Click:Connect(function()
	if canClick then
		print("Achat effectué !")
		-- Mettez ici le code de votre action d'achat (ex: déclencher un événement serveur)
		ScreenGui.Enabled = false
	else
		-- Optionnel : donner un petit feedback si le joueur clique trop tôt
		print("Veuillez patienter pendant le chargement...")
	end
end)

-- Keybind P et Fermeture
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.P then
		openMenu()
	end
end)

CloseBtn.MouseButton1Click:Connect(function()
	ScreenGui.Enabled = false
end)
